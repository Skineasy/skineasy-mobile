{
  "name": "skineasy-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "lint-staged": {
    "*.{ts,tsx,json,md}": "prettier --write"
  },
  "scripts": {
    "generate:assets": "node scripts/generate-assets.js",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" \"!node_modules/**\" \"!.expo/**\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\" \"!node_modules/**\" \"!.expo/**\"",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test",
    "prepare": "husky",
    "update:prod": "eas update --branch main --message \"$(git log -1 --pretty=%s)\" --non-interactive",
    "supabase:types": "supabase gen types typescript --project-id lyhhipvipgbqsytfqwdw > src/lib/supabase.types.ts"
  },
  "dependencies": {
    "@dev-plugins/react-query": "^0.4.0",
    "@hookform/resolvers": "^5.2.2",
    "@kingstinct/react-native-healthkit": "^14.0.0",
